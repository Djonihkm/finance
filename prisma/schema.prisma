generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String          @id @default(uuid())
  email                 String          @unique
  password              String
  nom                   String
  prenom                String
  role                  Role
  telephone             String?
  poste                 String?
  avatarUrl             String?
  isActive              Boolean         @default(true)
  deletedAt             DateTime?
  etablissementId       String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  bonsCreees            BonCommande[]   @relation("BonCreateur")
  bonsSignes            BonCommande[]   @relation("BonSignataire")
  bonsValides           BonCommande[]   @relation("BonValideur")
  depensesCreees        Depense[]       @relation("DepenseCreateur")
  depensesSignees       Depense[]       @relation("DepenseSignataire")
  depensesValidees      Depense[]       @relation("DepenseValideur")
  etablissementsCreates Etablissement[] @relation("EtablissementCreateur")
  historiques           Historique[]
  etablissement         Etablissement?  @relation("EtablissementUsers", fields: [etablissementId], references: [id])
  resetToken            String?         @unique
  resetTokenExp         DateTime?
}

model Etablissement {
  id          String            @id @default(uuid())
  nom         String
  code        String            @unique
  type        TypeEtablissement
  adresse     String?
  ville       String?
  region      String?
  telephone   String?
  email       String?
  logoUrl     String?
  isActive    Boolean           @default(true)
  deletedAt   DateTime?
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  bons        BonCommande[]
  budgets     Budget[]
  depenses    Depense[]
  createdBy   User              @relation("EtablissementCreateur", fields: [createdById], references: [id])
  users       User[]            @relation("EtablissementUsers")
}

model Budget {
  id              String        @id @default(uuid())
  annee           Int
  montantTotal    Decimal       @db.Decimal(15, 2)
  montantConsomme Decimal       @default(0) @db.Decimal(15, 2)
  etablissementId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id])

  @@unique([etablissementId, annee])
}

model Depense {
  id                    String           @id @default(uuid())
  reference             String           @unique
  intitule              String
  montant               Decimal          @db.Decimal(15, 2)
  categorie             CategorieDepense
  paiement              TypePaiement
  fournisseur           String?
  description           String?
  date                  DateTime
  statut                StatutDocument   @default(ATTENTE)
  signeParId            String?
  signeAt               DateTime?
  valideParId           String?
  valideAt              DateTime?
  commentaire           String?
  pieceJustificativeUrl String?
  etablissementId       String
  createdById           String
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?

  // Compte de charge (classe 6) — déjà existant, juste renommé pour clarté
  compteId             Int?
  compte               Compte?  @relation("DepenseCompteCharge", fields: [compteId], references: [id])

  // Compte de trésorerie (classe 5) — nouveau
  // Déduit automatiquement du mode de paiement lors de la validation
  // ESPECES → 5700 Caisse | VIREMENT/autres → 5200 Banque
  compteTresorerieId   Int?
  compteTresorerie     Compte?  @relation("DepenseCompteTresorerie", fields: [compteTresorerieId], references: [id])

  // Écritures comptables générées à la validation (partie double)
  ecritures            Ecriture[]

  createdBy     User          @relation("DepenseCreateur", fields: [createdById], references: [id])
  etablissement Etablissement @relation(fields: [etablissementId], references: [id])
  signePar      User?         @relation("DepenseSignataire", fields: [signeParId], references: [id])
  validePar     User?         @relation("DepenseValideur", fields: [valideParId], references: [id])
  historiques   Historique[]
}

model BonCommande {
  id                    String             @id @default(uuid())
  reference             String             @unique
  intitule              String
  fournisseur           String?
  description           String?
  date                  DateTime
  statut                StatutDocument     @default(ATTENTE)
  montantTotal          Decimal            @db.Decimal(15, 2)
  signeParId            String?
  signeAt               DateTime?
  valideParId           String?
  valideAt              DateTime?
  commentaire           String?
  pieceJustificativeUrl String?
  etablissementId       String
  createdById           String
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  deletedAt             DateTime?

  // Compte de charge (classe 6)
  compteId             Int?
  compte               Compte?  @relation("BonCommandeCompteCharge", fields: [compteId], references: [id])

  // Compte de trésorerie (classe 5) — nouveau
  compteTresorerieId   Int?
  compteTresorerie     Compte?  @relation("BonCommandeCompteTresorerie", fields: [compteTresorerieId], references: [id])

  // Écritures comptables générées à la validation
  ecritures            Ecriture[]

  createdBy     User               @relation("BonCreateur", fields: [createdById], references: [id])
  etablissement Etablissement      @relation(fields: [etablissementId], references: [id])
  signePar      User?              @relation("BonSignataire", fields: [signeParId], references: [id])
  validePar     User?              @relation("BonValideur", fields: [valideParId], references: [id])
  historiques   Historique[]
  lignes        LigneBonCommande[]
}

model LigneBonCommande {
  id            String      @id @default(uuid())
  designation   String
  quantite      Int
  prixUnitaire  Decimal     @db.Decimal(15, 2)
  montant       Decimal     @db.Decimal(15, 2)
  bonCommandeId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  bonCommande   BonCommande @relation(fields: [bonCommandeId], references: [id], onDelete: Cascade)
}

model Historique {
  id            String           @id @default(uuid())
  action        ActionHistorique
  commentaire   String?
  userId        String
  depenseId     String?
  bonCommandeId String?
  createdAt     DateTime         @default(now())
  bonCommande   BonCommande?     @relation(fields: [bonCommandeId], references: [id])
  depense       Depense?         @relation(fields: [depenseId], references: [id])
  user          User             @relation(fields: [userId], references: [id])
}

// ============================================================
// PLAN COMPTABLE
// ============================================================

model Classe {
  id      Int      @id @default(autoincrement())
  numero  String   @unique // "5", "6", "7"
  nom     String           // "Trésorerie", "Charges", "Produits"
  comptes Compte[]
}

model Compte {
  id       Int    @id @default(autoincrement())
  numero   String @unique
  nom      String
  classeId Int
  classe   Classe @relation(fields: [classeId], references: [id])

  parentId Int?
  parent   Compte?  @relation("CompteHierarchy", fields: [parentId], references: [id])
  enfants  Compte[] @relation("CompteHierarchy")

  // Relations vers les documents (nommées pour éviter l'ambiguïté)
  depensesCharge       Depense[]     @relation("DepenseCompteCharge")
  depensesTresorerie   Depense[]     @relation("DepenseCompteTresorerie")
  bonsCharge           BonCommande[] @relation("BonCommandeCompteCharge")
  bonsTresorerie       BonCommande[] @relation("BonCommandeCompteTresorerie")

  // Toutes les écritures passées sur ce compte
  ecritures            Ecriture[]
}

// ============================================================
// ÉCRITURES COMPTABLES — Partie double
// Chaque validation génère exactement 2 écritures :
//   DÉBIT  → compte de charge (classe 6) — la dépense augmente
//   CRÉDIT → compte de trésorerie (classe 5) — l'argent sort
// Règle : Σ débits = Σ crédits (équilibre comptable)
// ============================================================

model Ecriture {
  id      String       @id @default(uuid())
  date    DateTime     // date comptable de l'opération
  sens    SensEcriture // DEBIT ou CREDIT
  montant Decimal      @db.Decimal(15, 2)
  libelle String?      // description libre

  // Compte mouvementé
  compteId Int
  compte   Compte @relation(fields: [compteId], references: [id])

  // Source de l'écriture (l'un ou l'autre, jamais les deux)
  depenseId     String?
  depense       Depense?     @relation(fields: [depenseId], references: [id])
  bonCommandeId String?
  bonCommande   BonCommande? @relation(fields: [bonCommandeId], references: [id])

  createdAt DateTime @default(now())
}

// ============================================================
// ÉNUMÉRATIONS
// ============================================================

enum Role {
  SUPER_ADMIN
  MINISTERE
  ADMIN
  COMPTABLE
  DIRECTEUR
}

enum StatutDocument {
  ATTENTE
  REVIEW
  REVISION
  VALIDE
  REJETE
  PAYE     // futur module de paiement
}

enum TypeEtablissement {
  LYCEE
  COLLEGE
  CEG
  ECOLE_PRIMAIRE
  AUTRE
}

enum TypePaiement {
  ESPECES
  VIREMENT
  VIREMENT_30J
  VIREMENT_60J
  CHEQUE
  CARTE_BANCAIRE
  ACOMPTE
}

enum CategorieDepense {
  FOURNITURE
  MOBILIER
  PERSONNEL
  PEDAGOGIE
  EQUIPEMENT
  TRAVAUX
  AUTRE
}

enum ActionHistorique {
  CREE
  MODIFIE
  SOUMIS
  SIGNE
  VALIDE
  REJETE
  PAYE     // traçabilité du paiement
}

enum SensEcriture {
  DEBIT  // charge qui augmente / argent qui entre
  CREDIT // trésorerie qui diminue / argent qui sort
}